# Liaison.legal Web — Environment Variables
# These are set as Supabase secrets on the edge function, not in this repo.
# Run: supabase secrets set KEY=value

# Resend API key — for demo request notification emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where demo request notifications are delivered
DEMO_REQUEST_EMAIL=chris@liaison.legal

# Public app URL — used for cross-domain links (no trailing slash)
PUBLIC_APP_URL=https://app.liaison.legal
