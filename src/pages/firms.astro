---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="For Law Firms — The Forensic Audit Behind the Record | Liaison.legal"
  description="Liaison.legal gives family law firms free view-only access to client records, plus an AI Forensic Auditor that cross-references communications against the court order and produces a review-ready Declaration of Non-Compliance."
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="bg-navy py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-body text-sm font-medium text-sky uppercase tracking-widest mb-4">
          For family law attorneys, mediators, and evaluators
        </p>
        <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight">
          Stop reading months of messages.<br class="hidden md:block" />
          <span class="text-sky">Start reviewing findings.</span>
        </h1>
        <p class="font-body text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
          Liaison.legal's AI Forensic Auditor cross-references a client's communication record
          against the court order, flags potential deviations, and links every finding to the
          message behind it — so your team reviews a draft instead of assembling one.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#waitlist"
            class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-azure text-white font-body font-semibold text-lg hover:brightness-110 transition-all duration-200"
          >
            Request Firm Access →
          </a>
          <a
            href="#audit"
            class="inline-flex items-center justify-center px-8 py-4 rounded-full border-2 border-white/30 text-white font-body font-medium text-lg hover:border-white/70 transition-colors duration-200"
          >
            See how the audit works
          </a>
        </div>
      </div>
    </section>

    <!-- Answer-first -->
    <section class="bg-white py-10 px-6 border-b border-gray-200">
      <div class="max-w-3xl mx-auto">
        <p class="font-body text-base text-slate leading-relaxed">
          Liaison.legal is a co-parenting communication platform with an attorney-facing forensic
          audit. Any firm whose client uses Liaison.legal gets free, view-only access to that
          client's verified record. When a matter calls for it, the AI Forensic Auditor compares
          the communication history against the uploaded court order, surfaces potential behavioral
          and financial deviations, grounds each one in a specific message, and assembles a
          court-ready Declaration of Non-Compliance for an attorney to review, confirm, and sign.
          Firms pay per matter; parents never pay.
        </p>
      </div>
    </section>

    <!-- The Problem -->
    <section class="bg-gray-100 py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-6">
          The least billable hours in the building
        </h2>
        <p class="font-body text-lg text-slate leading-relaxed">
          Somewhere on your team, someone is reading six months of co-parenting messages to find
          the eight that matter. It's slow, it's a cost center, and it's the worst use of a
          paralegal's day. Meanwhile the evidence that wins the motion is buried in a thread no
          one has time to read end to end.
        </p>
      </div>
    </section>

    <!-- The Audit -->
    <section id="audit" class="bg-white py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-4">
          A neutral auditor, not a coach
        </h2>
        <p class="font-body text-lg text-slate leading-relaxed mb-10">
          Liaison.legal reads the record so your team doesn't have to:
        </p>
        <div class="space-y-5">
          {[
            ['Ingests the court order', 'Upload the judgment or parenting plan.'],
            ['Extracts the rules', 'Pick-up times, locations, notice periods, exchange terms.'],
            ['Cross-references the communication', 'Every message, against every rule.'],
            ['Flags potential deviations', 'Behavioral and financial, with severity and frequency.'],
            ['Grounds every finding', 'Each one hyperlinked to the exact message that supports it. No ungrounded claims.'],
            ['Assembles the Declaration', 'A court-ready Declaration of Non-Compliance, drafted for your review.'],
          ].map(([title, desc]) => (
            <div class="flex items-start gap-4 p-5 bg-gray-100 rounded-[var(--radius-lg)]">
              <span class="text-azure font-bold font-body mt-0.5 flex-shrink-0">→</span>
              <div>
                <span class="font-body font-semibold text-navy">{title}</span>
                <span class="font-body text-slate"> — {desc}</span>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-8 font-body text-sm text-gray-400 italic">
          The auditor identifies potential deviations in factual, cross-referenced terms. It does
          not draw legal conclusions and it does not advise. The interpretation — and the signature
          — stay with the attorney.
        </p>
      </div>
    </section>

    <!-- Human in the loop -->
    <section class="bg-navy py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-white mb-6">
          Your review is the work product
        </h2>
        <p class="font-body text-lg text-white/80 leading-relaxed">
          No finding leaves the system until an attorney reviews and confirms it. That step is
          deliberate. It's the safeguard against unauthorized practice of law, and it's what makes
          the finished Declaration your firm's billable work product — a deliverable added, not
          hours subtracted.
        </p>
      </div>
    </section>

    <!-- Why firms pay -->
    <section class="bg-white py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-6">
          Reallocate capacity to advocacy
        </h2>
        <p class="font-body text-lg text-slate leading-relaxed">
          The audit automates the work that never billed well anyway. The hours you save go back
          into higher-margin advocacy, the Declaration becomes a billable deliverable, and
          better-grounded evidence wins more matters. The precedent is e-discovery: once the tools
          existed, reading by hand stopped being defensible. Sell win-rate and capacity — not
          "time saved."
        </p>
      </div>
    </section>

    <!-- Pricing -->
    <section class="bg-gray-100 py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-10">
          How firm pricing works
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              title: 'Free view-only on-ramp',
              body: 'Read access to any client\'s record who already uses Liaison.legal, at no cost.',
            },
            {
              title: 'Per-matter audit & Declaration',
              body: 'Charged when the auditor is activated and a Declaration is produced. Priced to sit below the paralegal assembly hours it replaces, and pass-through-able as a client disbursement.',
            },
            {
              title: 'Volume subscription',
              body: 'For firms running enough matters that a flat license beats per-matter, bundling white-label branding.',
            },
          ].map(({ title, body }) => (
            <div class="bg-white rounded-[var(--radius-lg)] p-6" style="box-shadow: var(--shadow-card);">
              <h3 class="font-display font-semibold text-lg text-navy mb-3">{title}</h3>
              <p class="font-body text-sm text-slate leading-relaxed">{body}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm font-body text-gray-400 italic">
          Final per-matter pricing is being set with our launch cohort. Request access to discuss
          your firm's volume.
        </p>
      </div>
    </section>

    <!-- White-label -->
    <section class="bg-white py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-6">
          Your portal, your brand
        </h2>
        <p class="font-body text-lg text-slate leading-relaxed">
          The platform can carry your firm's branding, so the record your client builds lives
          inside your proprietary client portal. The firm is the hero; we're the engine.
        </p>
      </div>
    </section>

    <!-- Waitlist Form -->
    <section id="waitlist" class="bg-gray-100 py-20 px-6">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-3">
            See it on a real matter.
          </h2>
          <p class="font-body text-lg text-slate">
            We'll walk your team through a live audit on a sample case.
          </p>
        </div>

        <div class="bg-white rounded-[var(--radius-lg)] p-8 md:p-10" style="box-shadow: var(--shadow-card);">

          <form id="firm-waitlist-form" class="space-y-5">

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="firstName" class="block font-body text-sm font-medium text-navy mb-1.5">
                  First name <span class="text-danger">*</span>
                </label>
                <input type="text" id="firstName" name="firstName" required autocomplete="given-name"
                  class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all"
                  placeholder="Jane" />
              </div>
              <div>
                <label for="lastName" class="block font-body text-sm font-medium text-navy mb-1.5">
                  Last name <span class="text-danger">*</span>
                </label>
                <input type="text" id="lastName" name="lastName" required autocomplete="family-name"
                  class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all"
                  placeholder="Smith" />
              </div>
            </div>

            <div>
              <label for="email" class="block font-body text-sm font-medium text-navy mb-1.5">
                Email <span class="text-danger">*</span>
              </label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all"
                placeholder="jane@smithfamilylaw.com" />
            </div>

            <div>
              <label for="firmName" class="block font-body text-sm font-medium text-navy mb-1.5">
                Firm name <span class="text-danger">*</span>
              </label>
              <input type="text" id="firmName" name="firmName" required autocomplete="organization"
                class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all"
                placeholder="Smith Family Law" />
            </div>

            <div>
              <label for="message" class="block font-body text-sm font-medium text-navy mb-1.5">
                Anything you'd like us to know? <span class="font-normal text-gray-400">(optional)</span>
              </label>
              <textarea id="message" name="message" rows="3"
                class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all resize-none"
                placeholder="Volume, practice area, a case type you have in mind..."></textarea>
            </div>

            <button type="submit" id="firm-submit-btn"
              class="w-full py-4 px-6 rounded-full bg-navy text-white font-body font-semibold text-base hover:bg-azure transition-colors duration-200 disabled:opacity-60 disabled:cursor-not-allowed">
              Request Firm Access
            </button>

            <p class="text-xs font-body text-center text-gray-400">
              We'll be in touch within one business day.
            </p>
          </form>

          <div id="firm-form-success" class="hidden p-5 rounded-[var(--radius-md)] bg-gray-100 border border-gray-200">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-azure flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="font-body text-sm text-navy">
                Thank you — we'll be in touch within one business day to schedule your walk-through.
              </p>
            </div>
          </div>

          <div id="firm-form-error" class="hidden p-5 rounded-[var(--radius-md)] bg-red-50 border border-red-200">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-danger flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="font-body text-sm text-danger">
                Something went wrong. Please try again or email us at
                <a href="mailto:info@liaison.legal" class="underline font-medium">info@liaison.legal</a>.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  const form       = document.getElementById('firm-waitlist-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('firm-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('firm-form-success')!;
  const errorMsg   = document.getElementById('firm-form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorMsg.classList.add('hidden');

    const data: Record<string, string> = {};
    new FormData(form).forEach((value, key) => { data[key] = value as string; });

    try {
      const response = await fetch('https://formspree.io/f/mlgyreqv', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) throw new Error('Submission failed');

      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Request Firm Access';
    }
  });
</script>
