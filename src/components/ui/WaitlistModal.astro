---
// Replace PARENT_WAITLIST_FORMSPREE_ID with your Formspree form ID for the parent waitlist.
// Create a new form at https://formspree.io — keep it separate from the firms waitlist form.
---

<div
  id="waitlist-overlay"
  class="fixed inset-0 z-[200] hidden items-center justify-center p-4 bg-navy/70 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="waitlist-modal-title"
>
  <div
    id="waitlist-modal"
    class="w-full max-w-md bg-white rounded-[var(--radius-lg)] p-8 relative"
    style="box-shadow: var(--shadow-card);"
  >

    <!-- Close button -->
    <button
      id="waitlist-close"
      type="button"
      class="absolute top-4 right-4 p-1 text-gray-400 hover:text-navy transition-colors"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Beta badge -->
    <span class="inline-flex items-center px-3 py-1 rounded-full bg-sky/20 text-azure text-xs font-body font-semibold uppercase tracking-widest mb-5">
      Currently in Beta
    </span>

    <!-- Heading + subtext -->
    <h2 id="waitlist-modal-title" class="font-display font-bold text-2xl text-navy mb-2">
      Join the waitlist
    </h2>
    <p class="font-body text-sm text-slate leading-relaxed mb-6">
      Liaison.legal is in private beta. Enter your email and we'll reach out when your spot is ready — free for parents, always.
    </p>

    <!-- Form -->
    <form id="waitlist-form" class="space-y-4">
      <div>
        <label for="waitlist-email" class="block font-body text-sm font-medium text-navy mb-1.5">
          Email address
        </label>
        <input
          type="email"
          id="waitlist-email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-gray-200 bg-gray-100 font-body text-sm text-navy placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-azure focus:border-transparent transition-all"
        />
      </div>
      <button
        type="submit"
        id="waitlist-submit"
        class="w-full py-3 px-6 rounded-full bg-azure text-white font-body font-semibold text-sm hover:brightness-110 transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Notify me when ready
      </button>
    </form>

    <!-- Success -->
    <div id="waitlist-success" class="hidden p-4 rounded-[var(--radius-md)] bg-gray-100 border border-gray-200">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-azure flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="font-body text-sm text-navy font-medium">You're on the list — we'll be in touch.</p>
      </div>
    </div>

    <!-- Error -->
    <div id="waitlist-error" class="hidden p-4 rounded-[var(--radius-md)] bg-red-50 border border-red-200">
      <p class="font-body text-sm text-danger">
        Something went wrong. Please try again or email
        <a href="mailto:info@liaison.legal" class="underline">info@liaison.legal</a>.
      </p>
    </div>

  </div>
</div>

<script>
  const overlay    = document.getElementById('waitlist-overlay')!;
  const closeBtn   = document.getElementById('waitlist-close')!;
  const form       = document.getElementById('waitlist-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('waitlist-submit') as HTMLButtonElement;
  const successMsg = document.getElementById('waitlist-success')!;
  const errorMsg   = document.getElementById('waitlist-error')!;

  function openModal() {
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
    document.getElementById('waitlist-email')!.focus();
  }

  function closeModal() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Open from any [data-open-waitlist] element anywhere on the page
  document.addEventListener('click', (e) => {
    if ((e.target as Element).closest('[data-open-waitlist]')) {
      e.preventDefault();
      openModal();
    }
  });

  // Close handlers
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Formspree submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorMsg.classList.add('hidden');

    const email = (document.getElementById('waitlist-email') as HTMLInputElement).value;

    try {
      // Replace PARENT_WAITLIST_FORMSPREE_ID with your actual Formspree form ID
      const response = await fetch('https://formspree.io/f/mkolbjvk', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (!response.ok) throw new Error('Submission failed');

      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Notify me when ready';
    }
  });
</script>
