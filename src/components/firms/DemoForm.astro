---
---

<section id="demo-form" class="bg-warm-white py-20 px-6">
  <div class="max-w-2xl mx-auto">

    <div class="text-center mb-10">
      <p class="text-sm font-body font-medium text-sky uppercase tracking-widest mb-3">
        Get started
      </p>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-navy mb-3">
        Schedule a 20-Minute Walk-Through
      </h2>
      <p class="font-body text-[color:var(--color-text-muted)]">
        We'll show you the evidence ledger, the AI auditor, and the export flow.
        No sales pressure — just the product.
      </p>
    </div>

    <div class="bg-white rounded-[var(--radius-lg)] p-8 md:p-10" style="box-shadow: var(--shadow-card);">

      <form id="demo-request-form" class="space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="firstName" class="block font-body text-sm font-medium text-navy mb-1.5">
              First name <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              autocomplete="given-name"
              class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all"
              placeholder="Jane"
            />
          </div>
          <div>
            <label for="lastName" class="block font-body text-sm font-medium text-navy mb-1.5">
              Last name <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              autocomplete="family-name"
              class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all"
              placeholder="Smith"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block font-body text-sm font-medium text-navy mb-1.5">
            Email <span class="text-danger">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all"
            placeholder="jane@smithfamilylaw.com"
          />
        </div>

        <div>
          <label for="firmName" class="block font-body text-sm font-medium text-navy mb-1.5">
            Firm name <span class="text-danger">*</span>
          </label>
          <input
            type="text"
            id="firmName"
            name="firmName"
            required
            autocomplete="organization"
            class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all"
            placeholder="Smith Family Law"
          />
        </div>

        <div>
          <label for="phone" class="block font-body text-sm font-medium text-navy mb-1.5">
            Phone <span class="font-normal text-[color:var(--color-text-muted)]">(optional)</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            autocomplete="tel"
            class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all"
            placeholder="+1 (555) 000-0000"
          />
        </div>

        <div>
          <label for="message" class="block font-body text-sm font-medium text-navy mb-1.5">
            How did you hear about us? <span class="font-normal text-[color:var(--color-text-muted)]">(optional)</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full px-4 py-2.5 rounded-[var(--radius-md)] border border-cream bg-warm-white font-body text-sm text-navy placeholder:text-[color:var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-sky focus:border-transparent transition-all resize-none"
            placeholder="Referral, LinkedIn, bar association newsletter..."
          ></textarea>
        </div>

        <button
          type="submit"
          id="demo-submit-btn"
          class="w-full py-4 px-6 rounded-full bg-navy text-white font-body font-semibold text-base hover:bg-navy-mid transition-colors duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Request Walk-Through
        </button>

        <p class="text-xs font-body text-center text-[color:var(--color-text-muted)]">
          No spam. We'll reply within one business day to schedule a time.
        </p>

      </form>

      <!-- Success message -->
      <div id="demo-form-success" class="hidden p-5 rounded-[var(--radius-md)] bg-sage-light border border-sage">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-check flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="font-body text-sm text-navy">
            Thank you! We received your request and will be in touch within one business day to schedule your walk-through.
          </p>
        </div>
      </div>

      <!-- Error message -->
      <div id="demo-form-error" class="hidden p-5 rounded-[var(--radius-md)] bg-red-50 border border-red-200">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-danger flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="font-body text-sm text-danger">
            Something went wrong. Please try again or email us at
            <a href="mailto:chris@liaison.legal" class="underline font-medium">chris@liaison.legal</a>.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form       = document.getElementById('demo-request-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('demo-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('demo-form-success')!;
  const errorMsg   = document.getElementById('demo-form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorMsg.classList.add('hidden');

    const data: Record<string, string> = {};
    new FormData(form).forEach((value, key) => {
      data[key] = value as string;
    });

    try {
      const response = await fetch(
        'https://vpnvvehzkgwqojjiryke.supabase.co/functions/v1/demo-request',
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZwbnZ2ZWh6a2d3cW9qamlyeWtlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyODU5NzIsImV4cCI6MjA5MDg2MTk3Mn0.m1CbhggIdC5RVAcoLT8Ge8V5kk_rWZMhXyTb9Q9dthg',
          },
          body: JSON.stringify(data),
        }
      );

      if (!response.ok) throw new Error('Submission failed');

      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Request Walk-Through';
    }
  });
</script>
