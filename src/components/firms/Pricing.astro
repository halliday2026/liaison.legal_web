---
---

<section class="bg-cream py-20 px-6">
  <div class="max-w-4xl mx-auto">

    <div class="text-center mb-12">
      <p class="text-sm font-body font-medium text-sky uppercase tracking-widest mb-3">
        Simple, transparent pricing
      </p>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-navy">
        Pay for what you use
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Per-case card (white) -->
      <div class="bg-white rounded-[var(--radius-lg)] p-8 flex flex-col" style="box-shadow: var(--shadow-card);">
        <p class="text-sm font-body font-medium text-sky uppercase tracking-widest mb-2">
          Per Case
        </p>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-display font-bold text-5xl text-navy">$99</span>
          <span class="font-body text-[color:var(--color-text-muted)] mb-2">/case</span>
        </div>
        <p class="font-body text-sm text-[color:var(--color-text-muted)] mb-8">
          Activate attorney access on a single case. No subscription required.
        </p>
        <ul class="space-y-3 flex-1 mb-8">
          {[
            'Full evidence ledger access for one case',
            'AI forensic audit against one court order',
            'One-click court export (PDF + CSV)',
            'No expiry — access until case closes',
          ].map((item) => (
            <li class="flex items-start gap-2 font-body text-sm text-navy">
              <span class="text-check font-bold flex-shrink-0 mt-0.5">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="#demo-form"
          class="inline-flex items-center justify-center px-6 py-3 rounded-full border-2 border-navy text-navy font-body font-semibold hover:bg-navy hover:text-white transition-colors duration-200"
        >
          Get Started
        </a>
      </div>

      <!-- Firm license card (navy) -->
      <div class="bg-navy rounded-[var(--radius-lg)] p-8 flex flex-col relative overflow-hidden" style="box-shadow: var(--shadow-card);">
        <span class="absolute top-4 right-4 text-xs font-body font-semibold bg-gold text-navy px-3 py-1 rounded-full">
          Best for firms
        </span>
        <p class="text-sm font-body font-medium text-gold uppercase tracking-widest mb-2">
          Firm License
        </p>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-display font-bold text-5xl text-white">$250</span>
          <span class="font-body text-white/60 mb-2">–$750/mo</span>
        </div>
        <p class="font-body text-sm mb-8" style="color: var(--color-text-light);">
          Unlimited case activations. Full firm dashboard. Scales with your caseload.
        </p>
        <ul class="space-y-3 flex-1 mb-8">
          {[
            'Unlimited case activations per month',
            'Multi-attorney firm dashboard',
            'White-label client portal option',
            'Priority support & onboarding',
            'Custom court order templates',
          ].map((item) => (
            <li class="flex items-start gap-2 font-body text-sm text-white">
              <span class="text-gold font-bold flex-shrink-0 mt-0.5">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="#demo-form"
          class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-gold text-navy font-body font-semibold hover:brightness-105 transition-all duration-200"
        >
          Schedule Walk-Through
        </a>
      </div>

    </div>

    <p class="mt-6 text-xs font-body text-center text-[color:var(--color-text-muted)]">
      Parent accounts are always free. Firm pricing is for attorney-side access only.
      Contact us for volume pricing or multi-office arrangements.
    </p>

  </div>
</section>
