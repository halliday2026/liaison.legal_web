---
---

<section class="bg-navy py-20 px-6">
  <div class="max-w-6xl mx-auto text-center">

    <!-- Eyebrow badge -->
    <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-gold text-navy text-sm font-body font-semibold mb-6">
      For Family Law Firms
    </span>

    <!-- H1 -->
    <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white max-w-4xl mx-auto leading-tight mb-6">
      Your clients are already documenting.<br class="hidden md:block" />
      <span class="text-gold">Are you ready?</span>
    </h1>

    <!-- Subheadline -->
    <p class="font-body text-lg max-w-2xl mx-auto mb-12 leading-relaxed" style="color: var(--color-text-light);">
      Right now, your clients are screenshotting texts, saving emails, and building chaotic
      evidence files you'll need to make sense of anyway. Liaison.legal makes that evidence
      court-ready before they even walk through your door.
    </p>

    <!-- Dual CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a
        href="#demo-form"
        class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-gold text-navy font-body font-semibold text-lg hover:brightness-105 transition-all duration-200"
      >
        Schedule a 20-Minute Walk-Through
      </a>
      <a
        href="#"
        class="inline-flex items-center justify-center px-8 py-4 rounded-full border border-white/30 text-white font-body font-medium text-lg hover:border-white/60 transition-colors duration-200"
      >
        Download Firm Overview
        <span class="ml-2 text-sm opacity-60">PDF</span>
      </a>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Featured full-width on mobile, normal on desktop -->
      <div class="md:col-span-1 bg-navy-mid rounded-[var(--radius-lg)] p-6 text-center" style="box-shadow: var(--shadow-card);">
        <p class="font-display font-bold text-5xl text-gold mb-2">Months</p>
        <p class="font-body text-white/70 text-sm">of verified evidence ready before discovery</p>
      </div>

      <div class="bg-navy-mid rounded-[var(--radius-lg)] p-6 text-center" style="box-shadow: var(--shadow-card);">
        <p class="font-display font-bold text-5xl text-white mb-2">0 hrs</p>
        <p class="font-body text-white/70 text-sm">manual sorting of client screenshots</p>
      </div>

      <div class="bg-navy-mid rounded-[var(--radius-lg)] p-6 text-center" style="box-shadow: var(--shadow-card);">
        <p class="font-display font-bold text-5xl text-white mb-2">1-click</p>
        <p class="font-body text-white/70 text-sm">court-ready export for any date range</p>
      </div>

    </div>
  </div>
</section>
