---
import TrustStrip from '../ui/TrustStrip.astro';
---

<section class="bg-gray-100 py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

    <!-- Copy -->
    <div class="flex-1 text-center lg:text-left">
      <p class="font-body text-sm font-medium text-azure uppercase tracking-widest mb-4">
        Co-parenting communication, on the record
      </p>

      <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-navy leading-tight mb-6">
        Your messages are evidence.<br />
        <span class="text-azure">Treat them that way.</span>
      </h1>

      <p class="font-body text-lg text-slate max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
        Liaison.legal gives you a secure, timestamped record of every co-parenting message —
        automatically hashed, permanently logged, and ready for your attorney and the court.
        <strong class="text-navy">Free for parents, forever.</strong>
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-6">
        <a
          href="https://app.liaison.legal/signup"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-azure text-white font-body font-semibold text-lg hover:brightness-110 transition-all duration-200"
        >
          Start Free Account →
        </a>
        <a
          href="/how-it-works"
          class="inline-flex items-center justify-center px-8 py-4 rounded-full border-2 border-navy text-navy font-body font-medium text-lg hover:bg-navy hover:text-white transition-all duration-200"
        >
          See how it works
        </a>
      </div>

      <TrustStrip />
    </div>

    <!-- Phone mockup — hidden on mobile -->
    <div class="hidden md:flex flex-shrink-0 justify-center lg:justify-end" aria-hidden="true">
      <div
        class="relative w-[272px] rounded-[2.5rem] bg-navy p-3"
        style="box-shadow: 0 40px 80px rgba(1,59,132,0.25), 0 10px 20px rgba(1,59,132,0.12);"
      >
        <div class="bg-white rounded-[2rem] overflow-hidden">

          <!-- App header -->
          <div class="bg-navy px-4 py-3 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-azure flex items-center justify-center text-white text-xs font-bold font-body flex-shrink-0">
              JM
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-white text-xs font-body font-semibold truncate">Case #2024-1847</p>
              <p class="text-white/60 text-[10px] font-body">Jordan Mercer</p>
            </div>
            <span class="text-[10px] font-body font-bold bg-azure text-white px-2 py-0.5 rounded-full flex-shrink-0">
              VERIFIED
            </span>
          </div>

          <!-- Messages -->
          <div class="px-3 py-4 space-y-3 bg-gray-100/60">

            <div class="max-w-[85%]">
              <div class="bg-white rounded-2xl rounded-tl-sm px-3 py-2 shadow-sm">
                <p class="text-[11px] font-body text-navy leading-snug">
                  I need to pick up Emma at 5pm. The order says 4pm.
                </p>
              </div>
              <p class="text-[9px] font-body text-gray-400 mt-0.5 ml-1">✓ Read 9:14 AM</p>
            </div>

            <div class="max-w-[85%] ml-auto">
              <div class="bg-azure rounded-2xl rounded-tr-sm px-3 py-2">
                <p class="text-[11px] font-body text-white leading-snug">
                  The court order clearly states 4:00 PM at the school entrance.
                </p>
              </div>
              <p class="text-[9px] font-body text-gray-400 mt-0.5 text-right mr-1">Sent 9:16 AM</p>
            </div>

            <div class="max-w-[85%]">
              <div class="bg-white rounded-2xl rounded-tl-sm px-3 py-2 shadow-sm">
                <p class="text-[11px] font-body text-navy leading-snug">
                  I won't be able to make it by 4. Traffic.
                </p>
              </div>
              <p class="text-[9px] font-body text-gray-400 mt-0.5 ml-1">✓ Read 9:17 AM</p>
            </div>

            <div class="max-w-[85%] ml-auto">
              <div class="bg-azure rounded-2xl rounded-tr-sm px-3 py-2">
                <p class="text-[11px] font-body text-white leading-snug">
                  This message is being recorded per our court order.
                </p>
              </div>
              <p class="text-[9px] font-body text-gray-400 mt-0.5 text-right mr-1">Sent 9:18 AM</p>
            </div>
          </div>

          <!-- Hash strip -->
          <div class="bg-navy px-3 py-2 flex items-center gap-2">
            <div class="w-4 h-4 rounded bg-sky/30 flex items-center justify-center flex-shrink-0">
              <span class="text-sky text-[8px]">✓</span>
            </div>
            <p class="text-[9px] font-body text-white/60 truncate">
              SHA-256: a3f9e2c1… · Tamper-evident ledger
            </p>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>
