---
const features = [
  {
    icon: '🔗',
    title: 'Tamper-evident message ledger',
    description: 'Every message is cryptographically hashed with SHA-256 and chained to the record before it. The history can\'t be quietly edited or deleted after the fact.',
  },
  {
    icon: '👁️',
    title: 'Read & open confirmation',
    description: 'Exact timestamps for when each message is delivered and read. "I never saw that" stops being a defense.',
  },
  {
    icon: '🔒',
    title: 'Encrypted & access-controlled',
    description: 'Messages are encrypted in transit and at rest, with strict controls over who can ever see them.',
  },
  {
    icon: '📋',
    title: 'Complete, searchable history',
    description: 'A clean, chronological, verifiable record of every exchange — organized and ready the moment you need it.',
  },
  {
    icon: '📁',
    title: 'Document storage',
    description: 'Keep court orders, parenting plans, and case documents in the same secure place as your communication.',
  },
  {
    icon: '⚖️',
    title: 'Attorney-ready from day one',
    description: 'If you hire a lawyer, they get direct access to the verified record. No nights spent assembling screenshots.',
  },
];
---

<section class="bg-white py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-navy">
        Everything you need to protect yourself
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(({ icon, title, description }) => (
        <div class="bg-gray-100 rounded-[var(--radius-lg)] p-6" style="box-shadow: var(--shadow-card);">
          <div class="text-3xl mb-4">{icon}</div>
          <h3 class="font-display font-semibold text-lg text-navy mb-2">{title}</h3>
          <p class="font-body text-sm text-slate leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
