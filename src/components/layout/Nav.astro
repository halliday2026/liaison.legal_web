---
---
<header class="w-full bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-4" aria-label="Main navigation">

    <!-- Logo + wordmark -->
    <a href="/" class="inline-flex items-center gap-2.5 flex-shrink-0" aria-label="Liaison.legal home">
      <img src="/logo.svg" alt="" class="h-10 w-auto" aria-hidden="true" />
      <span class="font-wordmark font-medium text-lg text-navy tracking-tight hidden sm:inline">
        Liaison<span class="text-azure">.legal</span>
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-6 text-sm font-body font-medium">
      <a href="/how-it-works" class="text-slate hover:text-navy transition-colors duration-200">How It Works</a>
      <a href="/security" class="text-slate hover:text-navy transition-colors duration-200">Security &amp; Privacy</a>
      <a href="/free" class="text-slate hover:text-navy transition-colors duration-200">Free Promise</a>
      <a href="/faq" class="text-slate hover:text-navy transition-colors duration-200">FAQ</a>
      <!-- Visually set apart per deck spec -->
      <a
        href="/firms"
        class="text-azure border border-azure/30 px-3 py-1 rounded-full hover:bg-azure hover:text-white transition-colors duration-200"
      >
        For Law Firms
      </a>
    </div>

    <!-- Desktop CTA -->
    <a
      href="https://app.liaison.legal/signup"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden lg:inline-flex items-center px-5 py-2.5 rounded-full bg-azure text-white text-sm font-body font-semibold hover:brightness-110 transition-all duration-200 flex-shrink-0"
    >
      Start Free Account
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="lg:hidden flex flex-col gap-1.5 p-2 rounded-md hover:bg-gray-100 transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="w-5 h-0.5 bg-navy block transition-all" id="ham-1"></span>
      <span class="w-5 h-0.5 bg-navy block transition-all" id="ham-2"></span>
      <span class="w-5 h-0.5 bg-navy block transition-all" id="ham-3"></span>
    </button>

  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-gray-200 bg-white px-6 pb-6"
  >
    <div class="flex flex-col gap-4 pt-4 text-sm font-body font-medium">
      <a href="/how-it-works" class="text-slate hover:text-navy">How It Works</a>
      <a href="/security" class="text-slate hover:text-navy">Security &amp; Privacy</a>
      <a href="/free" class="text-slate hover:text-navy">Free Promise</a>
      <a href="/faq" class="text-slate hover:text-navy">FAQ</a>
      <a href="/firms" class="text-azure font-semibold">For Law Firms</a>
      <a
        href="https://app.liaison.legal/signup"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-5 py-3 rounded-full bg-azure text-white font-semibold mt-2"
      >
        Start Free Account
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
