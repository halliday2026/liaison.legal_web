---
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white/70 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8">
      <!-- Logo + tagline -->
      <div class="text-center md:text-left">
        <a href="/" class="font-display font-bold text-xl text-white">
          Liaison<span class="text-gold">.legal</span>
        </a>
        <p class="mt-1 text-sm">Court-admissible co-parenting communication.</p>
      </div>

      <!-- Links -->
      <nav class="flex flex-col sm:flex-row gap-4 text-sm text-center">
        <a href="/" class="hover:text-white transition-colors duration-200">For Parents</a>
        <a href="/firms" class="hover:text-white transition-colors duration-200">For Law Firms</a>
        <a
          href="https://app.liaison.legal/signup"
          class="hover:text-white transition-colors duration-200"
          target="_blank"
          rel="noopener noreferrer"
        >
          Create Free Account
        </a>
      </nav>
    </div>

    <hr class="border-white/10 my-8" />

    <div class="flex flex-col sm:flex-row justify-between gap-2 text-xs text-white/40">
      <p>&copy; {year} Liaison.legal. All rights reserved.</p>
      <p>Not a law firm. Does not provide legal advice.</p>
    </div>
  </div>
</footer>
