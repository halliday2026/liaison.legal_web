---
import EmergencyBoundary from '../ui/EmergencyBoundary.astro';
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white/80 pt-16 pb-8 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- 4-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2 mb-4" aria-label="Liaison.legal home">
          <img src="/logo.svg" alt="" class="h-8 w-auto brightness-0 invert" aria-hidden="true" />
          <span class="font-wordmark font-medium text-white text-base">Liaison<span class="text-sky">.legal</span></span>
        </a>
        <p class="text-sm leading-relaxed text-white/70 mb-4">
          Tamper-evident co-parenting communication. Free for parents, forever.
        </p>
        <p class="text-xs text-white/50 italic">Not a law firm. Does not provide legal advice.</p>
        <div class="mt-4 text-white/60">
          <EmergencyBoundary />
        </div>
      </div>

      <!-- Col 2: For Parents -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">For Parents</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/how-it-works" class="text-white/70 hover:text-white transition-colors">How It Works</a></li>
          <li><a href="/security" class="text-white/70 hover:text-white transition-colors">Security &amp; Privacy</a></li>
          <li><a href="/free" class="text-white/70 hover:text-white transition-colors">The Free Promise</a></li>
          <li><a href="/faq" class="text-white/70 hover:text-white transition-colors">FAQ</a></li>
          <li>
            <a
              href="https://app.liaison.legal/signup"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sky hover:text-white transition-colors font-medium"
            >
              Start Free Account
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: For Professionals -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">For Professionals</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/firms" class="text-white/70 hover:text-white transition-colors">For Law Firms</a></li>
          <li><a href="/firms#waitlist" class="text-white/70 hover:text-white transition-colors">Request Firm Access</a></li>
        </ul>
      </div>

      <!-- Col 4: Company / Legal -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">Company</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/privacy" class="text-white/70 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-white/70 hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="mailto:chris@liaison.legal" class="text-white/70 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

    </div>

    <hr class="border-white/10 mb-6" />

    <p class="text-xs text-white/40 text-center">
      &copy; {year} Liaison.legal — a Halliday company. All rights reserved.
    </p>

  </div>
</footer>
